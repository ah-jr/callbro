  "productName": "callbro",
  "version": "0.3.3",
  "identifier": "com.fazcapital.callbro",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "callbro",
        "width": 980,
        "height": 720,
        "minWidth": 640,
        "minHeight": 480,
        "resizable": true,
        "center": true
